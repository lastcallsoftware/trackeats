# Shared backend base URL for the React app and the static portfolio page.
# Vite reads this during `npm run dev` and `npm run build`, and the portfolio
# HTML is stamped with the same value at build time. Use the local backend here
# while developing, and the production API URL in production builds.
VITE_BACKEND_BASE_URL=http://localhost:5000
#VITE_BACKEND_BASE_URL_2=http://172.22.249.46:5000

VITE_PORTFOLIO_URL=/portfolio/index.html

# Public Cloudflare Turnstile site key for the portfolio contact form.
# This is the browser-facing key, not the backend secret.
VITE_TURNSTILE_SITE_KEY_PUBLIC=0x4AAAAAADMy2a3nd8krtoyn

# ── Social login (leave blank to disable a provider during development) ──────
# Google: create an OAuth 2.0 Web client ID at console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=925416842819-b5fthi6p9r10207s7hdlt9vi0kfviccr.apps.googleusercontent.com

# Facebook: get your App ID from developers.facebook.com
VITE_FACEBOOK_APP_ID=1790226149014594

# Apple: use the Services ID you created in the Apple Developer portal
VITE_APPLE_CLIENT_ID=

# Must match the redirect URI registered for this Services ID in Apple Developer
VITE_APPLE_REDIRECT_URI=http://localhost:5173/login
