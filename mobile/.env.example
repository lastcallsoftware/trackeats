# Configure the hostname/IP where the backend is running
# The 172.x.x.x address is the IP address of the WSL subsystem.  This changes every time
#   WSL restarts (including every reboot).  I previously used this when testing using a
#   virtual phone in the Android Studio, but it's no longer necessary.
#EXPO_PUBLIC_BACKEND_BASE_URL=http://172.19.77.76:5000
# The 10.x.x.x address is the IP address of the native Windows system.  This works with
#   both my real phone over Wifi, and with a virtual phone in Android Studio,
#   *provided the port forwarding is set up*.  This can be done using the "proxy.bat"
#   script in the /mobile/bin directory -- which, remember, must be run under native
#   Windows, not WSL.  Note also that the WSL IP address changes ever time you restart,
#   so the script must be rerun.  Not sure if this IP address also changes.  Probably!
EXPO_PUBLIC_BACKEND_BASE_URL=http://10.0.0.146:5000

# ── Social login ─────────────────────────────────────────────────────────────
# Google OAuth client IDs — create these at console.cloud.google.com
# webClientId is required on Android to receive an idToken; also used as
# the fallback on iOS if iosClientId is not set.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Facebook App ID — get from developers.facebook.com
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Apple Sign-In requires no client-side config — it uses the bundle ID
# configured in app.json and the Apple Developer portal.