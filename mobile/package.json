{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^expo-linking$": "<rootDir>/src/__mocks__/expo-linking.ts",
      "^expo-secure-store$": "<rootDir>/src/__mocks__/expo-secure-store.ts"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    }
  },
  "dependencies": {
    "@expo/cli": "^55.0.24",
    "@expo/metro-runtime": "~55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@tanstack/react-query": "^5.99.0",
    "@types/jest": "29.5.14",
    "axios": "^1.15.0",
    "expo": "~55.0.0",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.30",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.14",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "yup": "^1.7.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "expo-module-scripts": "^55.0.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
