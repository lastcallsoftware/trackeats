# Database config
# The root login is used when the database container is initialized.
# The app login is used by the app itself to connect to the database.
# It's highly debatable whether one should keep the username a secret, 
# but what the hell.
DB_HOSTNAME=
DB_DATABASE_NAME=
DB_ROOT_PASSWORD=
DB_APP_USERNAME=
DB_APP_PASSWORD=

# App config
# This is the URL for THIS server, needed for some embedded links.
# In the local .env use 127.0.0.1.  localhost would probably also work but
# allegedly there are cases where it is unreliable.
BACKEND_BASE_URL=https://trackeats.lastcallsw.com:5443

# Optional public URL to use in confirmation emails.
# If unset, confirmation links use BACKEND_BASE_URL.
# Useful for local development when the backend is exposed through a tunnel.
# This is necessary when doing email-based registration using the mobile app 
# on a local phone during development, because the phone can't talk directly to 
# the development PC, it can only talk to a URL on the public Internet.
# For local development, set this to a URL provided by cloudflared.
# The backend appends /api/confirm?token=... to this value.
CONFIRM_LINK_BASE_URL=https://evidence-cork-progressive-agents.trycloudflare.com 

# Where the backend should send mobile users after a confirmation email link
# has been validated.  The default is trackeats://confirm, which opens the
# installed mobile app through its custom URL scheme.
MOBILE_CONFIRM_REDIRECT_URL=trackeats://confirm

# The link to my personal webpage
PORTFOLIO_URL=./frontend/portfolio/index.html

# App passwords
# Passwords for the admin, test and guest accounts used to log into the app
# itself.  These are seeded into the User table when the app is initialized.
APP_ADMIN_PASSWORD=
APP_TEST_PASSWORD=
APP_GUEST_PASSWORD=

# SMTP config
# We're using an AWS service for the app's SMTP services.  Technically you 
# *can* set up your own SMTP server, but trust me, it's not worth the hassle.
# On the other hand you do have to "qualify" to use an AWS SMTP server.
# I can't remmber what I had to do except that it was a PITA.  This is to
# discourage spammers.
SMTP_HOSTNAME=
SMTP_USERNAME=
SMTP_PASSWORD=

# Security config
# This is a symmetric key used to encrypt sensitive data stored in the database.
# Generate one thus:
#   import secrets, base64
#   print(base64.b64encode(secrets.token_bytes(32)).decode())
# Technically it's equivalent to the sample code below for generating a JWT
# key, but this code makes it more explicit that it's a base64-encoded value.
BACKEND_ENCRYPTION_KEY_B64=

# JWT config
# For the JWT key, technically any text can be used ("hello world" works),
# but for optimal security it should generated with:
#   import secrets
#   print(secrets.token_urlsafe(32))
# If we were really hardcore, we'd have revocation and rotation 
# mechanisms for the key.  We're not hardcore.
JWT_SECRET_KEY=
# This is how long a JWT token lasts before expiring, in minutes.
# For testing you may want to knock it down to 1. The short lifetime
# is its main feature: it gives bad guys a short time to use it if
# they manage to steal one.  If we were using refresh tokens, 15 
# minutes would be a reasonable value.  Since we're not, 120 is fine.
ACCESS_TOKEN_DURATION=120

# Flask-Limiter storage backend.
# For single-process deployments, memory:// is sufficient.
# If you run multiple backend instances, use a shared backend like Redis.
RATELIMIT_STORAGE_URI=memory://

# If you want the backend to run in debug mode, which enables auto-reload
# when you change the code, set FLASK_DEBUG to 1.
#FLASK_DEBUG=1

# This tells the Flask CLI where to find the app's entry point.
# Only used locally, when running "flask db migrate" /upgrade.
#FLASK_APP=src/app:minimal_app_config

# ── Social login (server-side token verification) ────────────────────────────
# Google OAuth client IDs from console.cloud.google.com
# Backend accepts tokens issued for any configured client ID.
# GOOGLE_WEB_CLIENT_ID should match VITE_GOOGLE_CLIENT_ID in frontend .env.
# Note that Client IDs are public information.  They're basically like public crypto keys
# that you use to sign stuff.  The secret key is stored on the Google website that
# validates the logins.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Facebook: App ID and App Secret from developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Apple: Bundle ID of your iOS app (e.g. com.example.trackeats)
# For web sign-in this should be the Services ID (e.g. com.example.trackeats.web)
APPLE_BUNDLE_ID=

# Cloudflare Turnstile secret key
# This is used with Turnstile's CAPTCHA-like user validation.
# The flow is that when the user performs some action we want to protect, the frontend
# calls the Turnstile website, which validates the user using their funky magic and
# generates a token that it returns to the frontend.
# The frontend sends that token to the backend as a param to the API you want to protect.  
# The backend then validates the token by calling Turnstile with that token and this 
# secret key.
# Note that this doesn't authenticate the user, it just verifies them as being a human
# instead of a bot.  Allegedly.
TURNSTILE_SECRET_KEY=
